# Copy to .env and fill in. Semantic search needs no key; only LLM enrichment does.

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
GEN_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama — run a local open model for FREE (no key). Set LLM_PROVIDER=ollama.
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Real store connector (optional; the mock store needs nothing)
SHOPIFY_STORE=          # e.g. my-shop.myshopify.com
SHOPIFY_TOKEN=
